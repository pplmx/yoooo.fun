&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># ====== windows ======&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">mkdir &lt;span class="nv">$APPDATA&lt;/span>/pip
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">touch &lt;span class="nv">$APPDATA&lt;/span>/pip/pip.ini
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># or (This is a legacy configuration)&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">mkdir &lt;span class="nv">$HOME&lt;/span>/pip
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">touch &lt;span class="nv">$HOME&lt;/span>/pip/pip.ini
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
